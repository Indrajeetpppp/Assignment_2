# Task 2: Sum of numbers from 1 to 50

total = 0   # start with 0, this will hold the running sum

for i in range(1, 51):   # loop through numbers 1 to 50
    total += i           # add the current number to the running total
                         # after each iteration, total grows larger (like adding on paper)

print(f"The sum of numbers from 1 to 50 is: {total}")
